<Window x:Class="craftersmine.UI.Unity.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:craftersmine.UI.Unity.DemoApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Style="{DynamicResource UnityWindowStyle}">
    <WrapPanel>
        <GroupBox Header="Buttons" MinWidth="250" HorizontalContentAlignment="Stretch" Padding="10">
            <StackPanel>
                <Button Content="Button" Margin="1" Padding="10"/>
                <Button Content="Button" IsEnabled="False" Margin="1" Padding="10"/>
            </StackPanel>
        </GroupBox>
    </WrapPanel>
</Window>
