<Window x:Class="craftersmine.Ui.Unity.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:craftersmine.Ui.Unity.DemoApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Style="{DynamicResource UnityWindowStyle}" Icon="/about.png"
        ResizeMode="CanResize">
    <TabControl>
        <TabItem Header="Buttons">
            <TabItem.ToolTip>
                <TextBlock Text="Every available button in this style"/>
            </TabItem.ToolTip>
            <StackPanel>
                <Button Content="Button" Margin="1" Padding="10"/>
                <Button Content="Button" IsEnabled="False" Margin="1" Padding="10"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="CheckBoxes">
            <StackPanel>
                <CheckBox Content="Default"/>
                <CheckBox Content="Checked" IsChecked="True"/>
                <CheckBox Content="Indeterminate" IsThreeState="True" IsChecked="{x:Null}"/>
                <CheckBox Content="Disabled" IsEnabled="False"/>
                <CheckBox Content="CheckedDisabled" IsChecked="True" IsEnabled="False"/>
                <CheckBox Content="IndeterminateDisabled" IsThreeState="True" IsChecked="{x:Null}" IsEnabled="False"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="TextBoxes">
            <StackPanel>
                <GroupBox Header="TextBox">
                    <StackPanel>
                        <TextBox Text="Default"/>
                        <TextBox Text="Disabled" IsEnabled="False"/>
                        <TextBox Text="ReadOnly" IsReadOnly="True"/>
                        <TextBox Text="DisabledReadOnly" IsReadOnly="True" IsEnabled="False"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="PasswordBox">
                    <StackPanel>
                        <PasswordBox Password="Default"/>
                        <PasswordBox Password="Disabled" IsEnabled="False"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="Sliders">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal">
                    <Slider Orientation="Vertical"/>
                    <Slider IsEnabled="False" Orientation="Vertical"/>
                </StackPanel>
                <StackPanel>
                    <Slider/>
                    <Slider IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </TabItem>
        <TabItem Header="RadioButtons">
            <StackPanel>
                <StackPanel>
                    <RadioButton Content="Default"/>
                    <RadioButton IsChecked="True" Content="Checked"/>
                </StackPanel>
                <RadioButton IsEnabled="False" Content="Disabled"/>
                <RadioButton IsChecked="True" IsEnabled="False" Content="Disabled Checked"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="ComboBoxes">
            <StackPanel>
                <ComboBox SelectedIndex="0">
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Test" IsEnabled="False"/>
                    <ComboBoxItem Content="Test"/>
                </ComboBox>
                <ComboBox IsEnabled="False" SelectedIndex="0">
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Test"/>
                    <ComboBoxItem Content="Test"/>
                </ComboBox>
            </StackPanel>
        </TabItem>
        <TabItem Header="ProgressBars">
            <StackPanel Margin="4">
                <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100"/>
                <ProgressBar Value="{Binding ElementName=ProgressSlider, Path=Value}"/>
                <ProgressBar IsIndeterminate="True"/>
            </StackPanel>
        </TabItem>
        <TabItem Header="Expanders">
            <StackPanel>
                <Expander Header="Inspector Style">
                    <TextBlock Text="Unity UI is interesting"/>
                </Expander>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
