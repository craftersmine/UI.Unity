        <TabItem Header="ListViews">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TreeView Grid.Column="0">
                    <TreeViewItem IsExpanded="True">
                        <TreeViewItem.Header>
                            <TextBlock Text="Favourites" FontWeight="Bold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="All Materials"/>
                        <TreeViewItem Header="All Models"/>
                        <TreeViewItem Header="All Prefabs"/>
                    </TreeViewItem>
                    <TreeViewItem IsEnabled="False"/>
                    <TreeViewItem IsExpanded="True">
                        <TreeViewItem.Header>
                            <TextBlock Text="Assets" FontWeight="Bold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Content"/>
                        <TreeViewItem Header="Editor"/>
                        <TreeViewItem Header="Prefabs" IsEnabled="False"/>
                        <TreeViewItem Header="Scripts">
                            <TreeViewItem Header="Player Controlers"/>
                            <TreeViewItem Header="NPC"/>
                            <TreeViewItem Header="Systems"/>
                        </TreeViewItem>
                        <TreeViewItem Header="Scenes"/>
                    </TreeViewItem>
                    <TreeViewItem>
                        <TreeViewItem.Header>
                            <TextBlock Text="Packages" FontWeight="Bold"/>
                        </TreeViewItem.Header>
                        <TreeViewItem Header="Burst" IsEnabled="False"/>
                        <TreeViewItem Header="Unity UI"/>
                        <TreeViewItem Header="Universal RP"/>
                        <TreeViewItem Header="Visual Studio Editor"/>
                    </TreeViewItem>
                </TreeView>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="2"/>

                <ListBox Grid.Column="2" SelectionMode="Extended">
                    <ListBoxItem Content="Content"/>
                    <ListBoxItem Content="Editor"/>
                    <ListBoxItem Content="Models"/>
                    <ListBoxItem Content="Scenes"/>
                    <ListBoxItem Content="Scripts"/>
                </ListBox>
                
                <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="2"/>
                
                <ListView Grid.Column="4" ItemsSource="{DynamicResource Assets}" SelectionMode="Extended">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="S" DisplayMemberBinding="{Binding Path=Symbol}"/>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Path=Name}"/>
                            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Path=Type}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.Resources>
                        <collections:ArrayList x:Key="Assets">
                            <demoapp:DebugItem Symbol="O" Name="Material1.mat" Type="Material"/>
                            <demoapp:DebugItem Symbol="O" Name="Material2.mat" Type="Material"/>
                            <demoapp:DebugItem Symbol="O" Name="Material3.mat" Type="Material"/>
                            <demoapp:DebugItem Symbol="P" Name="Table.prefab" Type="Prefab"/>
                            <demoapp:DebugItem Symbol="P" Name="Character.prefab" Type="Prefab"/>
                        </collections:ArrayList>
                    </ListView.Resources>
                </ListView>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
