                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="BackgroundColor">#383838</Color>
    <Color x:Key="ForegroundColor">#fff</Color>

    <sys:Double x:Key="ButtonBorderOpacity">0.4</sys:Double>
    <Color x:Key="ButtonBackgroundColor">#585858</Color>
    <Color x:Key="ButtonHoverBackgroundColor">#676767</Color>
    <Color x:Key="ButtonBorderColor">#242424</Color>
    <Color x:Key="ButtonPressedBorderColor">#0D0D0D</Color>
    
</ResourceDictionary>