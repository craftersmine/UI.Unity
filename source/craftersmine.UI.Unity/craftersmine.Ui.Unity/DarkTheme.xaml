<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:local="clr-namespace:craftersmine.UI.Unity">

    <Color x:Key="BackgroundColor">#383838</Color>
    <Color x:Key="ForegroundColor">#fff</Color>
    <Color x:Key="HighlightTextColor">#3662a0</Color>

    <sys:Double x:Key="ButtonBorderOpacity">0.4</sys:Double>
    <Color x:Key="ButtonBackgroundColor">#585858</Color>
    <Color x:Key="ButtonHoverBackgroundColor">#676767</Color>
    <Color x:Key="ButtonBorderColor">#242424</Color>
    <Color x:Key="ButtonPressedBorderColor">#0D0D0D</Color>

    <Color x:Key="CheckboxBackgroundColor">#2a2a2a</Color>
    <Color x:Key="CheckboxTopBorderColor">#0d0d0d</Color>
    <Color x:Key="CheckboxBorderColor">#212121</Color>
    <Color x:Key="CheckboxTopHoverBorderColor">#656565</Color>
    <Color x:Key="CheckboxHoverBorderColor">#656565</Color>

    <Color x:Key="TextBoxBackgroundColor">#2a2a2a</Color>
    <Color x:Key="TextBoxTopBorderColor">#0d0d0d</Color>
    <Color x:Key="TextBoxBorderColor">#212121</Color>
    <Color x:Key="TextBoxTopHoverBorderColor">#656565</Color>
    <Color x:Key="TextBoxHoverBorderColor">#656565</Color>

    <Color x:Key="SliderTrackColor">#5e5e5e</Color>
    <Color x:Key="SliderHandleColor">#999999</Color>
    <Color x:Key="SliderHandleHoverColor">#EAEAEA</Color>
    <sys:Double x:Key="SliderHandleFocusedBorderOpacity">0.5</sys:Double>

</ResourceDictionary>