<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity">

    <SolidColorBrush x:Key="ListViewBackgroundBrush" Color="{DynamicResource ListViewBackgroundColor}"/>

    <SolidColorBrush x:Key="ListViewItemSelectedBackgroundBrush" Color="{DynamicResource ListViewItemSelectedBackgroundColor}"/>
    <SolidColorBrush x:Key="ListViewItemFocusedBackgroundBrush" Color="{local:ColorBlend {DynamicResource UnityUIAccentColor}, DarkGray, 0.3}"/>

    <SolidColorBrush x:Key="ListViewGridViewHeaderBackgroundBrush" Color="{DynamicResource ListViewGridViewHeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="ListViewGridViewHeaderBorderBrush" Color="{DynamicResource ListViewGridViewHeaderBorderColor}"/>

    <Style x:Key="ListViewGridViewScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{DynamicResource ListViewBackgroundBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Margin="{TemplateBinding Padding}">
                            <ScrollViewer DockPanel.Dock="Top"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Focusable="False">
                                <GridViewHeaderRowPresenter Columns="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.Columns}"
                                                            ColumnHeaderContainerStyle="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.ColumnHeaderContainerStyle}"
                                                            ColumnHeaderTemplate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.ColumnHeaderTemplate}"
                                                            ColumnHeaderTemplateSelector="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.ColumnHeaderTemplateSelector}"
                                                            AllowsColumnReorder="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.AllowsColumnReorder}"
                                                            ColumnHeaderContextMenu="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.ColumnHeaderContextMenu}"
                                                            ColumnHeaderToolTip="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplatedParent.View.ColumnHeaderToolTip}"/>
                            </ScrollViewer>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    CanContentScroll="False"
                                                    KeyboardNavigation.DirectionalNavigation="Local"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"/>
                        </DockPanel>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Orientation="Vertical"
                                   Grid.Column="1"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Orientation="Horizontal"
                                   Grid.Row="1"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Thumb" x:Key="GridViewColumnHeaderGripper">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <Rectangle HorizontalAlignment="Center"
                                   Width="1"
                                   Fill="Transparent"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Grid>
                        <Border Background="{DynamicResource ListViewGridViewHeaderBackgroundBrush}"
                                BorderBrush="{DynamicResource ListViewGridViewHeaderBorderBrush}"
                                BorderThickness="1 1 0 1">
                            <ContentPresenter TextElement.FontWeight="Bold" TextElement.FontSize="14pt" Margin="6 4 0 4"/>
                        </Border>
                        <Thumb x:Name="PART_HeaderGripper" Style="{DynamicResource GridViewColumnHeaderGripper}"
                               HorizontalAlignment="Right"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Role" Value="Floating">
                <Setter Property="Opacity" Value="0.7"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Canvas x:Name="PART_FloatingHeaderCanvas">
                                <Rectangle Fill="#60383838"
                                           Width="{TemplateBinding ActualWidth}"
                                           Height="{TemplateBinding ActualHeight}"/>
                            </Canvas>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <Style TargetType="ListView">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border Background="{DynamicResource ListViewBackgroundBrush}">
                        <ScrollViewer Style="{DynamicResource ListViewGridViewScrollViewerStyle}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsGrouping" Value="True">
                            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListViewItem">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="MaxHeight" Value="16"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="ListViewItemRoot" SnapsToDevicePixels="True" MinHeight="{TemplateBinding MinHeight}" IsHitTestVisible="True" HorizontalAlignment="Stretch">
                        <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="Stretch"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ListViewItemRoot" Property="Background" Value="{DynamicResource ListViewItemSelectedBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="ListViewItemRoot" Property="Background" Value="{DynamicResource ListViewItemFocusedBackgroundBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>