<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PasswordBoxTopBorderBrush" Color="{DynamicResource TextBoxTopBorderColor}"/>
    <SolidColorBrush x:Key="PasswordBoxBorderBrush" Color="{DynamicResource TextBoxBorderColor}"/>
    <SolidColorBrush x:Key="PasswordBoxHoverTopBorderBrush" Color="{DynamicResource TextBoxTopHoverBorderColor}"/>
    <SolidColorBrush x:Key="PasswordBoxHoverBorderBrush" Color="{DynamicResource TextBoxHoverBorderColor}"/>
    <SolidColorBrush x:Key="PasswordBoxFocusedTopBorderBrush" Color="{DynamicResource UnityUIAccentColor}"/>
    <SolidColorBrush x:Key="PasswordBoxFocusedBorderBrush" Color="{DynamicResource UnityUIAccentColor}"/>

    <SolidColorBrush x:Key="PasswordBoxBackgroundBrush" Color="{DynamicResource TextBoxBackgroundColor}"/>
    <SolidColorBrush x:Key="PasswordBoxForegroundBrush" Color="{DynamicResource UnityUIAccentColor}"/>

    <Style TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource InterFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource ControlForegroundBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="MinHeight" Value="18"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="CaretBrush" Value="{DynamicResource ControlForegroundBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border>
                        <Border x:Name="BorderTop" BorderBrush="{DynamicResource PasswordBoxTopBorderBrush}" Background="{DynamicResource PasswordBoxBackgroundBrush}" BorderThickness="0 1 0 0" CornerRadius="1.5">
                            <Border x:Name="Border" BorderBrush="{DynamicResource PasswordBoxBorderBrush}" BorderThickness="1 0 1 1" CornerRadius="1.5">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BorderTop" Property="BorderBrush" Value="{DynamicResource PasswordBoxHoverTopBorderBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PasswordBoxHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="BorderTop" Property="BorderBrush" Value="{DynamicResource PasswordBoxForegroundBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PasswordBoxForegroundBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>