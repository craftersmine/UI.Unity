<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity">

    <LinearGradientBrush x:Key="ProgressBarFillBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource UnityUIAccentColor}" Offset="0"/>
        <GradientStop Color="{DynamicResource UnityUIAccentColor}" Offset="0.1"/>
        <GradientStop Color="{local:ColorBlend {DynamicResource UnityUIAccentColor}, {DynamicResource ProgressBarBackgroundColor}, .4}" Offset="0.1"/>
        <GradientStop Color="{local:ColorBlend {DynamicResource UnityUIAccentColor}, {DynamicResource ProgressBarBackgroundColor}, .4}" Offset="0.9"/>
        <GradientStop Color="{local:ColorBlend {DynamicResource UnityUIAccentColor}, {DynamicResource ProgressBarBackgroundColor}, .6}" Offset="0.9"/>
        <GradientStop Color="{local:ColorBlend {DynamicResource UnityUIAccentColor}, {DynamicResource ProgressBarBackgroundColor}, .6}" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ProgressBarBorderBrush" Color="{DynamicResource ProgressBarBorderColor}"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="{DynamicResource ProgressBarBackgroundColor}"/>
    <local:WidthConverter x:Key="ProgressWidthConverter"/>

    <Style TargetType="ProgressBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border BorderBrush="{DynamicResource ProgressBarBorderBrush}" Background="{DynamicResource ProgressBarBackgroundBrush}" BorderThickness="1" x:Name="PART_Track" MinHeight="15">
                        <Border Background="{DynamicResource ProgressBarFillBrush}" HorizontalAlignment="Left" x:Name="PART_Indicator"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>