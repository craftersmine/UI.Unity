<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="RadioButtonBackgroundBrush" Color="{DynamicResource RadioButtonBackgroundColor}"/>
    <SolidColorBrush x:Key="RadioButtonForegroundFocusedBrush" Color="{DynamicResource UnityUIAccentColor}"/>
    <SolidColorBrush x:Key="RadioButtonBorderBrush" Color="{DynamicResource RadioButtonBorderColor}"/>
    <SolidColorBrush x:Key="RadioButtonHoverBorderBrush" Color="{DynamicResource RadioButtonHoverBorderColor}"/>
    <SolidColorBrush x:Key="RadioButtonFocusedBorderBrush" Color="{DynamicResource UnityUIAccentColor}"/>
    <SolidColorBrush x:Key="RadioButtonCheckedDotBrush" Color="{DynamicResource RadioButtonCheckedDotColor}"/>

    <Style TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{DynamicResource InterFont}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <BulletDecorator Margin="0"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Width="14"
                                         Height="14">
                            <Border x:Name="RadioButtonOuterBorder"
                                    BorderBrush="{DynamicResource RadioButtonBorderBrush}"
                                    Background="{DynamicResource RadioButtonBackgroundBrush}"
                                    BorderThickness="1.4"
                                    CornerRadius="7">
                                <Border x:Name="RadioButtonCheckedDot"
                                        Background="{DynamicResource RadioButtonCheckedDotBrush}"
                                        Width="6"
                                        Height="6"
                                        CornerRadius="3"
                                        HorizontalAlignment="Center"/>
                            </Border>
                        </BulletDecorator>
                        <ContentPresenter Grid.Column="1" Margin="4 0 0 0"
                                          Focusable="False"
                                          x:Name="RadioButtonContent"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RadioButtonOuterBorder" Property="BorderBrush" Value="{DynamicResource RadioButtonHoverBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="RadioButtonOuterBorder" Property="BorderBrush" Value="{DynamicResource RadioButtonFocusedBorderBrush}"/>
                            <Setter TargetName="RadioButtonContent" Property="TextElement.Foreground" Value="{DynamicResource RadioButtonForegroundFocusedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RadioButtonOuterBorder" Property="BorderBrush" Value="{DynamicResource RadioButtonFocusedBorderBrush}"/>
                            <Setter TargetName="RadioButtonContent" Property="TextElement.Foreground" Value="{DynamicResource RadioButtonForegroundFocusedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="RadioButtonCheckedDot" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>