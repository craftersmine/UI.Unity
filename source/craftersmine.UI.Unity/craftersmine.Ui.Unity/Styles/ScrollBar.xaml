<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ScrollBarBorderBrush" Color="{DynamicResource ScrollBarBorderColor}"/>
    <SolidColorBrush x:Key="ScrollBarBackgroundBrush" Color="{DynamicResource ScrollBarBackgroundColor}"/>
    <SolidColorBrush x:Key="ScrollBarGlyphBrush" Color="{DynamicResource ScrollBarGlyphColor}"/>
    <SolidColorBrush x:Key="ScrollBarHandleBrush" Color="{DynamicResource ScrollBarHandleColor}"/>
    <SolidColorBrush x:Key="ScrollBarHandleHoverBrush" Color="{DynamicResource ScrollBarHandleHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarButtonBackgroundBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarButtonHoverBackgroundBrush" Color="White" Opacity="0.2"/>

    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Visibility" Value="Visible"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarVerticalThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="5"
                            Background="{DynamicResource ScrollBarHandleBrush}"
                            BorderThickness="0"
                            Width="{TemplateBinding Width}"
                            MinWidth="{TemplateBinding MinWidth}"
                            x:Name="Thumb"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollBarHandleHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollBarHandleBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarHorizontalThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="MinHeight" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="5"
                            Background="{DynamicResource ScrollBarHandleBrush}"
                            BorderThickness="0"
                            Height="{TemplateBinding Height}"
                            MinHeight="{TemplateBinding MinHeight}"
                            x:Name="Thumb"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollBarHandleHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource ScrollBarHandleBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ScrollBarVertical" TargetType="ScrollBar">
        <Border BorderBrush="{DynamicResource ScrollBarBorderBrush}" BorderThickness="1 0 1 0" Background="{DynamicResource ScrollBarBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MaxHeight="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto" MaxHeight="16"/>
                </Grid.RowDefinitions>
                <RepeatButton Grid.Row="0" Width="13" Height="16" Background="Transparent" BorderBrush="Transparent" Margin="-1 0 -1 0" Command="ScrollBar.LineUpCommand">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="ButtonRoot">
                                <Path Width="8" Height="5" Fill="{DynamicResource ScrollBarGlyphBrush}" Data="M0,5L4,0L4,0L8,5"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="#1fffffff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>
                <Track x:Name="PART_Track" IsDirectionReversed="True" Grid.Row="1">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{DynamicResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="ScrollBarThumb"
                               Style="{DynamicResource ScrollBarVerticalThumb}"
                               Width="10"
                               Margin="1 0 1 0"
                               Background="Transparent"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{DynamicResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="2" Width="13" Height="16" Background="Transparent" BorderBrush="Transparent" Margin="-1 0 -1 0" Command="ScrollBar.LineDownCommand">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="ButtonRoot">
                                <Path Width="8" Height="5" Fill="{DynamicResource ScrollBarGlyphBrush}" Data="M0,0L8,0L4,5"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="#1fffffff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>
            </Grid>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="ScrollBarHorizontal" TargetType="ScrollBar">
        <Border BorderBrush="{DynamicResource ScrollBarBorderBrush}" BorderThickness="0 1 0 1" Background="{DynamicResource ScrollBarBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MaxWidth="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MaxWidth="16"/>
                </Grid.ColumnDefinitions>
                <RepeatButton Grid.Column="0" Width="16" Height="13" Background="Transparent" BorderBrush="Transparent" Margin="0 -1 0 -1" Command="ScrollBar.LineLeftCommand">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="ButtonRoot">
                                <Path Width="5" Height="8" Fill="{DynamicResource ScrollBarGlyphBrush}" Data="M5,0L5,8L1,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="#1fffffff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>
                <Track x:Name="PART_Track" Grid.Column="1">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{DynamicResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="ScrollBarThumb"
                               Style="{DynamicResource ScrollBarHorizontalThumb}"
                               Height="10"
                               Margin="1 0 1 0"
                               Background="Transparent"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{DynamicResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="2" Width="16" Height="13" Background="Transparent" BorderBrush="Transparent" Margin="0 -1 0 -1" Command="ScrollBar.LineRightCommand">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="ButtonRoot">
                                <Path Width="5" Height="8" Fill="{DynamicResource ScrollBarGlyphBrush}" Data="M0,0L0,8L4,4"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="#1fffffff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonRoot" Property="Background" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>
            </Grid>
        </Border>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template" Value="{DynamicResource ScrollBarHorizontal}"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{DynamicResource ScrollBarVertical}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>