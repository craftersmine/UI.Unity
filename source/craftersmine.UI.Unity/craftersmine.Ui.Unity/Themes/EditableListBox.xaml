<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity.Controls">

    <Style TargetType="{x:Type local:EditableListBox}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:EditableListBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{DynamicResource UnityListBoxBorderBrush}" Background="{DynamicResource UnityListBoxBackgroundBrush}" BorderThickness="1" CornerRadius="2" Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border x:Name="HeaderBorder" Background="{DynamicResource UnityListBoxHeaderBackgroundBrush}" BorderBrush="{DynamicResource UnityListBoxBorderBrush}" BorderThickness="0 0 0 1" Grid.Row="0" Height="18">
                                    <ContentPresenter Margin="8 0 0 0" VerticalAlignment="Center" HorizontalAlignment="Stretch" ContentSource="Header"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" Margin="0 2 0 2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1" BorderBrush="{DynamicResource UnityListBoxBorderBrush}" BorderThickness="1 0 1 1" Padding="2" Margin="0 -1 0 0" Background="{DynamicResource UnityListBoxBackgroundBrush}" CornerRadius="0 0 2 2">
                                <StackPanel Orientation="Horizontal">
									<Button x:Name="AddButton" Style="{DynamicResource UnityListBoxButtonStyle}">
										<Path Width="10" Height="10" Stroke="{DynamicResource ControlForegroundBrush}" StrokeThickness="2" Data="M5,0L5,10M0,5L10,5"/>
									</Button>
                                    <Button x:Name="RemoveButton" Style="{DynamicResource UnityListBoxButtonStyle}">
                                        <Path Width="10" Height="10" Stroke="{DynamicResource ControlForegroundBrush}" StrokeThickness="2" Data="M1.5,5L8.5,5"/>
									</Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="RemoveButton" Property="IsEnabled" Value="False"/>
                        </Trigger>
					</ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>