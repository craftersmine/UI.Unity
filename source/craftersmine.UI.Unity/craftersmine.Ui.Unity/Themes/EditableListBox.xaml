<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity.Controls">

    <Style TargetType="{x:Type local:EditableListBox}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:EditableListBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{DynamicResource UnityListBoxBorderBrush}" Background="{DynamicResource UnityListBoxBackgroundBrush}" BorderThickness="1" CornerRadius="2" Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{DynamicResource UnityListBoxHeaderBackgroundBrush}" BorderBrush="{DynamicResource UnityListBoxBorderBrush}" BorderThickness="0 0 0 1" Grid.Row="0">
                                    <TextBlock Margin="8 0 0 0" Text="Header"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" Margin="0 2 0 2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="16"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1" BorderBrush="{DynamicResource UnityListBoxBorderBrush}" BorderThickness="1 0 1 1" Padding="2" Margin="0 -1 0 0" Background="{DynamicResource UnityListBoxBackgroundBrush}" CornerRadius="0 0 2 2">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="+"/>
                                    <Button Content="-"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>