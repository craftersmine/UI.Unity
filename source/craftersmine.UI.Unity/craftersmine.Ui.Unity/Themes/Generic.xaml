<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:craftersmine.Ui.Unity.Controls">

    <SolidColorBrush x:Key="UnityHelpBoxForegroundBrush" Color="{DynamicResource UnityHelpBoxForegroundColor}"/>

    <Style TargetType="{x:Type local:HelpBox}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource UnityHelpBoxForegroundBrush}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource UnityHelpBoxForegroundBrush}"/>
        <Setter Property="TextElement.FontSize" Value="8pt"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HelpBox}">
                    <Border Background="{DynamicResource GroupBoxBackgroundBrush}"
                            BorderBrush="{DynamicResource GroupBoxBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2">
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="HelpBoxIcon" Source="{DynamicResource UnityHelpBoxErrorIcon}"/>
                            <ContentPresenter Grid.Column="1" Margin="2" VerticalAlignment="Center" TextElement.FontSize="8pt" TextElement.Foreground="{DynamicResource UnityHelpBoxForegroundBrush}" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Type" Value="Error">
                            <Setter TargetName="HelpBoxIcon" Property="Source" Value="{DynamicResource UnityHelpBoxErrorIcon}"/>
                        </Trigger>
                        <Trigger Property="Type" Value="Info">
                            <Setter TargetName="HelpBoxIcon" Property="Source" Value="{DynamicResource UnityHelpBoxInfoIcon}"/>
                        </Trigger>
                        <Trigger Property="Type" Value="Warning">
                            <Setter TargetName="HelpBoxIcon" Property="Source" Value="{DynamicResource UnityHelpBoxWarnIcon}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>
