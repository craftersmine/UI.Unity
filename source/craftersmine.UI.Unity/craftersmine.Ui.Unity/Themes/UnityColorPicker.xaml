<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity.Controls">

    <Style TargetType="{x:Type local:UnityColorPicker}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="MinHeight" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:UnityColorPicker}">
                    <Border x:Name="PickerRoot" Background="{DynamicResource UnityPickerButtonBackgroundBrush}" BorderBrush="{DynamicResource UnityPickerBorderBrush}" BorderThickness="1" CornerRadius="0 2 2 0" IsHitTestVisible="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="3"/>
                                </Grid.RowDefinitions>
                                <Rectangle x:Name="SelectedColorRectangle" Grid.Row="0" IsHitTestVisible="False" Fill="Black"/>
                                <Border x:Name="AlphaIndicatorTrack" Grid.Row="1" Background="Black" MinHeight="3">
                                    <Border HorizontalAlignment="Left" x:Name="AlphaIndicator" Background="White"/>
                                </Border>
                            </Grid>
                            <Grid Grid.Column="1">
                                <Image Source="{DynamicResource UnityEyeDropperIcon}" Width="14" Height="14"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderFocusedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundHoverBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>