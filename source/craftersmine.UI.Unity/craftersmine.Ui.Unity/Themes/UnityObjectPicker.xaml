<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.Ui.Unity.Controls">

    <Style TargetType="{x:Type local:UnityObjectPicker}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="MinHeight" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:UnityObjectPicker}">
                    <Border x:Name="PickerRoot" Background="{DynamicResource UnityPickerButtonBackgroundBrush}" 
                            BorderBrush="{DynamicResource UnityPickerBorderBrush}" 
                            BorderThickness="1" CornerRadius="0 2 2 0" 
                            IsHitTestVisible="True" Height="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <Border>
                                <Grid Background="{DynamicResource UnityPickerContentBackgroundBrush}" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Image x:Name="TypeIcon" Grid.Column="0" Source="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ObjectIcon}"/>
                                    <ContentPresenter x:Name="ContentPresenter" Grid.Column="1" Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ObjectName}"/>
                                </Grid>
                            </Border>
                            <Image Grid.Column="1" Source="{DynamicResource UnityObjectSelectorIcon}" Width="10" Height="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderFocusedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundHoverBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PickerRoot" Property="Background" Value="{DynamicResource UnityPickerButtonBackgroundBrush}"/>
                            <Setter TargetName="PickerRoot" Property="BorderBrush" Value="{DynamicResource UnityPickerBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                        <Trigger Property="SelectedObject" Value="{x:Null}">
                            <Setter TargetName="ContentPresenter" Property="Content" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=NullPlaceholder}"/>
                            <Setter TargetName="TypeIcon" Property="Source" Value="{x:Null}"/>
                        </Trigger>
                        <Trigger Property="ObjectIcon" Value="{x:Null}">
                            <Setter TargetName="TypeIcon" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>