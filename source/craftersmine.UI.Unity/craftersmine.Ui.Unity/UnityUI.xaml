<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:craftersmine.UI.Unity">

    <FontFamily x:Key="InterFont">./craftersmine.Ui.Unity;component/Fonts/#Inter</FontFamily>

    <Color x:Key="UnityUIAccentColor">#3A79BB</Color>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{local:ColorBlend {DynamicResource BackgroundColor}, {DynamicResource UnityUIAccentColor}, 0.8}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{local:ColorBlend {DynamicResource BackgroundColor}, {DynamicResource UnityUIAccentColor}, 0.8}"/>

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/PasswordBox.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/TextBlock.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/CheckBox.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/Button.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/TextBox.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/Slider.xaml"/>
        <ResourceDictionary Source="/craftersmine.UI.Unity;component/Styles/Window.xaml"/>
    </ResourceDictionary.MergedDictionaries>
</ResourceDictionary>